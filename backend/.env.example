# =============================================================================
# GEMINI CHATBOT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# Generate JWT secret: openssl rand -hex 32

# -----------------------------------------------------------------------------
# REQUIRED: Gemini API Configuration
# -----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (options: gemini-1.5-flash, gemini-2.0-flash-exp, gemini-1.5-pro)
GEMINI_MODEL=gemini-2.0-flash-exp

# -----------------------------------------------------------------------------
# REQUIRED: Database Configuration
# -----------------------------------------------------------------------------
# For local development (SQLite):
DATABASE_URL=sqlite:///./chat.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:port/database
# Example: postgresql://chatbot:mypass@localhost:5432/chatbot_db

# -----------------------------------------------------------------------------
# REQUIRED: JWT Authentication
# -----------------------------------------------------------------------------
# Generate a secure secret key: openssl rand -hex 32
JWT_SECRET_KEY=

# Algorithm for JWT encoding (don't change unless you know what you're doing)
JWT_ALGORITHM=HS256

# Token expiration in minutes (10080 = 7 days)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# OPTIONAL: Email/SMTP Configuration
# -----------------------------------------------------------------------------
# Leave empty to use console logging instead of sending real emails
# For Gmail: Use App Password (not your regular password)
# https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Gemini Chatbot

# -----------------------------------------------------------------------------
# OPTIONAL: CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# For development: http://localhost:3000
# For production: https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# OPTIONAL: Performance Tuning
# -----------------------------------------------------------------------------
# Maximum number of conversation exchanges to include in context
MAX_HISTORY_LIMIT=5

# How often frontend polls for notifications (seconds)
NOTIFICATION_POLL_INTERVAL=10

# Gemini API rate limit handling
RATE_LIMIT_MAX_RETRIES=3
RATE_LIMIT_BACKOFF_BASE=5

# -----------------------------------------------------------------------------
# OPTIONAL: Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features
# ENABLE_EPISODIC_MEMORY=true
# ENABLE_EMAIL_NOTIFICATIONS=true
# ENABLE_PROFILING=true
